{
  "name": "huntlo-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Huntlo production backend API and worker",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:api": "tsx watch src/server.ts",
    "worker": "node --import tsx src/worker.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.build.json && node --import tsx scripts/copy-voice-assets.ts",
    "start": "node dist/server.js",
    "start:api": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.build.json --noEmit"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parse": "^7.0.1",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^5.0.1",
    "helmet": "^8.0.0",
    "imapflow": "^1.4.7",
    "jsonwebtoken": "^9.0.3",
    "mailparser": "^3.9.14",
    "mongoose": "^8.9.3",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "pino": "^9.6.0",
    "pino-http": "^10.3.0",
    "razorpay": "^2.9.8",
    "standardwebhooks": "^1.0.0",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mailparser": "^3.4.6",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^8.0.1",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.5.13",
    "mongodb-memory-server": "^10.1.3",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
