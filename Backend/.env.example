# Server
PORT=4000
APP_ENV=development

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/huntlo

# Auth (use long random strings in production)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long!

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# AES-256-GCM — 32-byte key as 64-char hex
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Realtime WebSocket
REALTIME_ENABLED=false
REALTIME_WS_PATH=/realtime/v1

# Optional
LOG_LEVEL=info

# Future Jobs (candidate sourcing) — mock by default when no API key / in test
FUTURE_JOBS_API_URL=https://prod.api.futurejobs.ai/api/v1
FUTURE_JOBS_API_KEY=
FUTURE_JOBS_AUTH_STYLE=x-fj-api-key
# FUTURE_JOBS_USE_MOCK=true
FUTURE_JOBS_TIMEOUT_MS=30000
FUTURE_JOBS_MAX_RETRIES=2
FUTURE_JOBS_CIRCUIT_FAILURE_THRESHOLD=5
FUTURE_JOBS_CIRCUIT_RESET_MS=60000

# Optional — sourcing interpret enhancement (no-op when empty)
GEMINI_API_KEY=

# --- Integrations (optional; providers degrade gracefully when unset) ---
# Gmail (@react-oauth/google auth-code + postmessage redirect)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft Outlook / Graph (PKCE)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
# MICROSOFT_OAUTH_REDIRECT_URI=http://localhost:3000/integrations/outlook/callback

# Zoho Mail
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
# ZOHO_OAUTH_REDIRECT_URI=http://localhost:3000/integrations/zoho/callback

# Meta WhatsApp Cloud API
META_GRAPH_API_VERSION=v21.0
META_WEBHOOK_VERIFY_TOKEN=
HUNTLO_WHATSAPP_PHONE_NUMBER_ID=
HUNTLO_WHATSAPP_ACCESS_TOKEN=
HUNTLO_WHATSAPP_WABA_ID=

# Gupshup WhatsApp (platform-managed)
GUPSHUP_USERID=
GUPSHUP_PASSWORD=
# GUPSHUP_TEMPLATE_USER_ID=
# GUPSHUP_TEMPLATE_PASSWORD=
# GUPSHUP_REPLY_USER_ID=
# GUPSHUP_REPLY_PASSWORD=

# Hunar AI Voice
HUNAR_VOICE_API_KEY=
HUNAR_VOICE_PERSONA=NEHA
HUNAR_VOICE_LANGUAGE=ENGLISH
# Shared secret for inbound Hunar callbacks (optional in local/dev)
HUNAR_WEBHOOK_SECRET=
# Public base URL used in Hunar callback_config (no trailing slash)
PUBLIC_API_BASE_URL=http://localhost:4000

# Assessments provider — mock (default) or external (adapter stub until docs uploaded)
ASSESSMENT_PROVIDER=mock

# Calendly webhook HMAC signing key (optional in local/dev — verification skipped when empty)
CALENDLY_WEBHOOK_SIGNING_KEY=

# Razorpay (INR checkout) — never expose secret keys to the frontend
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Optional dedicated webhook secret; falls back to KEY_SECRET when empty
RAZORPAY_WEBHOOK_SECRET=

# Dodo Payments (USD / global checkout)
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=
DODO_PAYMENTS_ENVIRONMENT=test_mode
DODO_PRODUCT_ID_STARTER=
DODO_PRODUCT_ID_GROWTH=
DODO_PRODUCT_ID_SCALE=
